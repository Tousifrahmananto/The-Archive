# Vercel Blob token used by API routes
# Create this token in Vercel Dashboard -> Storage -> Blob -> Tokens
BLOB_READ_WRITE_TOKEN=
# Supabase project settings
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: Supabase Storage backend (used if BLOB_READ_WRITE_TOKEN is not set)
# Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name (defaults to "pdfs")
SUPABASE_STORAGE_BUCKET=pdfs
